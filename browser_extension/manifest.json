{
  "manifest_version": 3,
  "name": "AFWAH - Misinformation Detector",
  "version": "1.0.0",
  "description": "Real-time fact-checking overlay for social media posts",
  
  "permissions": [
    "activeTab",
    "scripting",
    "webRequest",
    "storage"
  ],
  
  "host_permissions": [
    "https://twitter.com/*",
    "https://x.com/*",
    "https://www.facebook.com/*",
    "https://www.reddit.com/*",
    "https://tiktok.com/*"
  ],
  
  "action": {
    "default_popup": "popup.html",
    "default_title": "AFWAH Fact Checker",
    "default_icon": {
      "16": "images/icon-16.png",
      "48": "images/icon-48.png",
      "128": "images/icon-128.png"
    }
  },
  
  "background": {
    "service_worker": "background.js"
  },
  
  "content_scripts": [
    {
      "matches": [
        "https://twitter.com/*",
        "https://x.com/*",
        "https://www.facebook.com/*",
        "https://www.reddit.com/*"
      ],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_end"
    }
  ],
  
  "icons": {
    "16": "images/icon-16.png",
    "48": "images/icon-48.png",
    "128": "images/icon-128.png"
  }
}
